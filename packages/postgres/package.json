    "event-store",
    "eventstore",
    "projection",
    "outbox",
    "outbox-pattern",
    "dlq",
    "dead-letter-queue",
    "snapshot",
    "partitioning",
    "multi-tenancy",
    "multi-tenant",
    "typescript",
    "eventfabric"
  ],
  "license": "MIT",
  "author": "Hi-Mind Limited",
  "repository": {
    "type": "git",
    "url": "https://github.com/hi-mind-ltd/eventfabric",
    "directory": "packages/postgres"
  },
  "version": "0.1.7",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
