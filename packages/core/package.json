{
  "name": "@eventfabric/core",
  "description": "Event sourcing core for TypeScript: aggregates, event store + outbox interfaces, inline / catch-up / async projections, snapshots, multi-tenancy, upcasters. Backend-agnostic — pair with @eventfabric/postgres.",
  "keywords": [
    "event",
    "events",
    "event-driven",
    "event-sourcing",
    "eventsourcing",
    "cqrs",
    "ddd",
    "domain-driven-design",
    "aggregate",
    "event-store",
    "eventstore",
    "projection",
    "outbox",
    "outbox-pattern",
    "snapshot",
    "upcaster",
    "multi-tenancy",
    "multi-tenant",
    "typescript"
  ],
  "license": "MIT",
  "author": "Hi-Mind Limited",
  "repository": {
    "type": "git",
    "url": "https://github.com/hi-mind-ltd/eventfabric",
    "directory": "packages/core"
  },
  "version": "0.1.8",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "vitest": "^2.1.8",
    "typescript": "^5.6.3"
  }
}