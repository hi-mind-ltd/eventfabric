    "tracing",
    "metrics",
    "projection",
    "async-projection",
    "catch-up-projection",
    "outbox",
    "typescript",
    "eventfabric"
  ],
  "license": "MIT",
  "author": "Hi-Mind Limited",
  "repository": {
    "type": "git",
    "url": "https://github.com/hi-mind-ltd/eventfabric",
    "directory": "packages/opentelemetry"
  },
  "version": "0.1.8",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
