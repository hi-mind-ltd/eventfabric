    "@opentelemetry/context-async-hooks": "^1.26.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-metrics": "^1.26.0",
    "@opentelemetry/resources": "^1.26.0",
    "vitest": "^2.1.8",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
